<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔═════════════════════════════════════════════════════════════════════════════╗
  ║  Languages/English/Keyed/RobotRepairStation.xml                             ║
  ║  Strings traducibles del mod — idioma base: Inglés                          ║
  ╠═════════════════════════════════════════════════════════════════════════════╣
  ║  Propósito:                                                                 ║
  ║    Centraliza todos los textos visibles al jugador en un único archivo.     ║
  ║    RimWorld usa un sistema de "Keyed translations": el código C# y el XML   ║
  ║    de Defs referencian una clave (key), y el sistema de localización        ║
  ║    resuelve la clave al texto correspondiente en el idioma activo.          ║
  ║                                                                             ║
  ║  Sistema de traducción de RimWorld:                                         ║
  ║    - Este archivo es la definición BASE (inglés).                           ║
  ║    - Para añadir soporte a otro idioma (p.ej. español), crear el archivo:   ║
  ║        Languages/Spanish/Keyed/RobotRepairStation.xml                       ║
  ║      con las mismas claves y los valores traducidos.                        ║
  ║    - Si una clave no existe en el idioma activo, RimWorld usa el inglés     ║
  ║      como fallback automático.                                              ║
  ║                                                                             ║
  ║  Convenciones de este archivo:                                              ║
  ║    - Prefijo RRS_ en todas las claves para evitar colisiones con otros      ║
  ║      mods o con el juego base.                                              ║
  ║    - Las claves con {0}, {1}, etc. son plantillas con parámetros            ║
  ║      posicionales que se sustituyen en runtime por .Translate(arg0, arg1).  ║
  ║    - Las claves marcadas [RESERVED] están declaradas para uso futuro pero   ║
  ║      no tienen referencia activa en el código C# actual. Se conservan para  ║
  ║      facilitar extensiones sin romper traducciones existentes.              ║
  ║                                                                             ║
  ║  Uso en C#:                                                                 ║
  ║    "CLAVE".Translate()           → texto sin parámetros                     ║
  ║    "CLAVE".Translate(arg0)       → texto con un parámetro ({0})             ║
  ║    "CLAVE".Translate(arg0, arg1) → texto con dos parámetros ({0}, {1})      ║
  ╚═════════════════════════════════════════════════════════════════════════════╝
-->
<LanguageData>

  <!-- ══════════════════════════════════════════════════════════════════════════
       INSPECTOR PANEL — Panel de inspección del edificio
       ══════════════════════════════════════════════════════════════════════════
       Textos mostrados en el panel de inspección (barra inferior de la UI)
       cuando el jugador selecciona el edificio.
       Generados por Building_RobotRepairStation.GetInspectString().
  -->

  <!--
    Mostrado cuando hay un mecanoid en reparación activa.
    {0} se sustituye por mechanoid.LabelShort (nombre corto del mecanoid).
    Ejemplo: "Repairing: Scyther-1"
  -->
  <RRS_InspectorCurrentOccupant>Repairing: {0}</RRS_InspectorCurrentOccupant>

  <!--
    Mostrado cuando la estación está encendida y sin ocupante.
    Indica al jugador que la estación está operativa pero esperando.
  -->
  <RRS_InspectorEmpty>Idle - waiting for damaged mechanoid</RRS_InspectorEmpty>

  <!--
    Mostrado cuando el CompPowerTrader.PowerOn == false.
    Indica que la estación no funciona por falta de energía eléctrica.
  -->
  <RRS_InspectorNoPower>No power - station offline</RRS_InspectorNoPower>

  <!--
    Mostrado cuando steelBuffer == 0 durante una reparación activa.
    Indica que la reparación está detenida por falta de acero en el buffer.
    NOTA: este mensaje se muestra junto al nombre del ocupante, no en lugar de él.
  -->
  <RRS_InspectorNoSteel>No steel - repairs halted</RRS_InspectorNoSteel>


  <!-- ══════════════════════════════════════════════════════════════════════════
       GIZMO BUTTONS — Botones de la barra de gizmos del edificio
       ══════════════════════════════════════════════════════════════════════════
       Textos de los botones que aparecen en la barra inferior cuando el jugador
       selecciona la estación. Generados por Building_RobotRepairStation.GetGizmos().
  -->

  <!--
    [RESERVED] Etiqueta del botón de ajuste de umbral de reparación.
    Reservado para una futura ventana de configuración del umbral de salud.
    Actualmente el umbral solo se ajusta desde el XML del ThingDef.
  -->
  <RRS_GizmoSetThreshold>Set repair threshold</RRS_GizmoSetThreshold>

  <!--
    [RESERVED] Tooltip del botón de umbral.
  -->
  <RRS_GizmoSetThresholdDesc>Set the health percentage at which mechanoids will seek this repair station.</RRS_GizmoSetThresholdDesc>

  <!--
    Etiqueta del botón de expulsión manual.
    Visible SOLO cuando IsOccupied == true (hay un mecanoid en la estación).
    Al pulsarlo llama a Building_RobotRepairStation.EjectOccupant().
  -->
  <RRS_GizmoEjectOccupant>Eject mechanoid</RRS_GizmoEjectOccupant>

  <!--
    Tooltip del botón de expulsión. Explica al jugador el efecto de la acción.
  -->
  <RRS_GizmoEjectOccupantDesc>Force the current mechanoid to leave the repair station.</RRS_GizmoEjectOccupantDesc>


  <!-- ══════════════════════════════════════════════════════════════════════════
       LETTERS / NOTIFICATIONS — Cartas y mensajes de notificación
       ══════════════════════════════════════════════════════════════════════════
       Este mod usa Messages.Message() (mensaje pequeño en la esquina superior)
       en lugar de Find.LetterStack.ReceiveLetter() (carta con popup), para no
       interrumpir al jugador en eventos rutinarios de reparación.
  -->

  <!--
    [RESERVED] Título para uso futuro si se migra a cartas formales.
  -->
  <RRS_LetterRepairCompleteLabel>Repair complete</RRS_LetterRepairCompleteLabel>

  <!--
    Texto del mensaje positivo cuando un mecanoid termina de repararse.
    {0} = mechanoid.LabelShort.
    Ejemplo: "Scyther-1 has been fully repaired at the robot repair station."
    Generado en CompRobotRepairStation.OnRepairComplete().
  -->
  <RRS_LetterRepairCompleteText>{0} has been fully repaired at the robot repair station.</RRS_LetterRepairCompleteText>

  <!--
    [RESERVED] Título para uso futuro si se migra a cartas formales.
  -->
  <RRS_LetterNoSteelLabel>Repair halted</RRS_LetterNoSteelLabel>

  <!--
    Texto del mensaje negativo cuando la estación se queda sin acero.
    {0} = nombre del mecanoid afectado (o "mechanoid" si currentOccupant es null).
    Ejemplo: "The robot repair station has run out of steel and cannot continue repairing Scyther-1."
    Generado en Building_RobotRepairStation.TryConsumeSteel().
  -->
  <RRS_LetterNoSteelText>The robot repair station has run out of steel and cannot continue repairing {0}.</RRS_LetterNoSteelText>


  <!-- ══════════════════════════════════════════════════════════════════════════
       STAT LABELS — Etiquetas de estadísticas personalizadas
       ══════════════════════════════════════════════════════════════════════════
       [RESERVED] Reservadas para StatDefs personalizados (carpeta Defs/StatDefs/
       pendiente de implementar). Permiten añadir una estadística "Repair Speed"
       modificable por investigaciones o por otras facilidades sin romper
       traducciones existentes.
  -->

  <RRS_StatRepairSpeed>Repair speed</RRS_StatRepairSpeed>
  <RRS_StatRepairSpeedDesc>How quickly this station repairs mechanoid health per day.</RRS_StatRepairSpeedDesc>

</LanguageData>
