<?xml version="1.0" encoding="utf-8"?>

<Patch>

  <!-- ── Inject repair subtree into the MechanoidConstant think tree ───── -->
  <Operation Class="PatchOperationInsert">
    <xpath>/Defs/ThinkTreeDef[defName="MechanoidConstant"]/thinkRoot/subNodes/li[@Class="ThinkNode_Priority"]/subNodes/li[@Class="ThinkNode_Subtree" and subtreeDef="MechanoidConstantCharge"][1]</xpath>
    <order>Before</order>
    <value>
      <!-- Conditional: is the mechanoid damaged below the repair threshold
           AND is there a powered, reachable repair station nearby? -->
      <li Class="RobotRepairStation.ThinkNode_ConditionalNeedsRepair">
        <subNodes>
          <li Class="RobotRepairStation.JobGiver_GoToRepairStation"/>
        </subNodes>
      </li>
    </value>
    <success>Always</success>
  </Operation>

</Patch>
