<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔═════════════════════════════════════════════════════════════════════════════╗
  ║  Defs/ResearchProjectDefs/ResearchDefs.xml                                  ║
  ║  Proyecto de investigación para desbloquear el Robot Repair Station         ║
  ╠═════════════════════════════════════════════════════════════════════════════╣
  ║  Propósito:                                                                 ║
  ║    Define el nodo de investigación "Mechanoid Repair Systems" en el árbol   ║
  ║    de tecnología del juego. Completar esta investigación es el requisito    ║
  ║    previo para construir el edificio RRS_RobotRepairStation.                ║
  ║                                                                             ║
  ║  Carpeta:                                                                   ║
  ║    Este archivo reside en Defs/ResearchProjectDefs/ (no en ThingDefs/)      ║
  ║    para seguir la convención estándar de RimWorld: cada tipo de Def en su   ║
  ║    propia subcarpeta. RimWorld carga todos los XML de Defs/ sin importar    ║
  ║    el nombre de subcarpeta, pero la organización correcta facilita la       ║
  ║    colaboración y la validación con herramientas externas.                  ║
  ║                                                                             ║
  ║  Relaciones con otros archivos:                                             ║
  ║    - defName referenciado en Defs/ThingDefs/Buildings_RobotRepairStation.xml║
  ║      (campo <researchPrerequisites>)                                        ║
  ║    - prerequisites apunta a "MechanoidBasics", investigación del DLC        ║
  ║      BioTech que desbloquea la creación básica de mecanoides                ║
  ╚═════════════════════════════════════════════════════════════════════════════╝
-->
<Defs>

  <!--
    ══════════════════════════════════════════════════════════════════════════════
    MECHANOID REPAIR SYSTEMS — ResearchProjectDef
    ══════════════════════════════════════════════════════════════════════════════
    Un ResearchProjectDef define un nodo en el árbol de tecnología del juego.
    Los nodos son visibles en la pestaña Research y se investigan usando una
    mesa de trabajo (Research Bench / Hi-Tech Research Bench).
  -->
  <ResearchProjectDef>

    <!--
      Identificador único de la investigación en el DefDatabase.
      Prefijo RRS_ para evitar colisiones con otros mods.
      Referenciado en Buildings_RobotRepairStation.xml como prerequisito de
      construcción del edificio.
    -->
    <defName>RRS_RobotRepairResearch</defName>

    <!--
      Nombre visible en el árbol de tecnología y en los tooltips.
      Se muestra en minúsculas por convención de RimWorld para nombres de
      investigaciones (el juego capitaliza automáticamente en algunos contextos).
    -->
    <label>mechanoid repair systems</label>

    <!--
      Descripción completa del proyecto de investigación.
      Aparece en el tooltip al pasar el cursor sobre el nodo en el árbol de
      tecnología. Debe explicar qué se está investigando y qué se desbloquea
      al completarlo.
    -->
    <description>Develop automated repair systems capable of diagnosing and restoring damaged mechanoids. Unlocks the Robot Repair Station, which allows mechanoids to self-repair when their health is critically low.</description>

    <!--
      Coste base de investigación en puntos de investigación.
      1200 puntos es un coste de gama media-alta para una tecnología Spacer:
        - Investigaciones básicas:   300-600 puntos.
        - Investigaciones medias:    600-1200 puntos.
        - Investigaciones avanzadas: 1200-4000 puntos.
    -->
    <baseCost>1200</baseCost>

    <!--
      Nivel tecnológico requerido para investigar este proyecto.
      Spacer requiere una Hi-Tech Research Bench.
      Es el nivel apropiado para tecnología de reparación de mecanoides,
      consistente con otras investigaciones del DLC BioTech.
    -->
    <techLevel>Spacer</techLevel>

    <!--
      Investigaciones previas obligatorias.
      MechanoidBasics: desbloquea la mecanoide básica en BioTech.
      Es el prerrequisito lógico antes de "reparación automatizada".
    -->
    <prerequisites>
      <li>MechanoidBasics</li>
    </prerequisites>

    <!--
      Coordenadas en el árbol de tecnología visual.
      Ajustar si hay colisiones con otras investigaciones de BioTech o de otros mods.
    -->
    <researchViewX>12.0</researchViewX>
    <researchViewY>4.5</researchViewY>

    <!--
      Pestaña del árbol de tecnología.
      "Biotech" agrupa todas las investigaciones del DLC BioTech.
    -->
    <tab>Biotech</tab>

  </ResearchProjectDef>

</Defs>