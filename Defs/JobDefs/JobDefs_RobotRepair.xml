<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Job: El mecanoid va a la estación de reparación para ser reparado -->
  <JobDef>
    <defName>RRS_GoToRepairStation</defName>
    <label>go to repair station</label>
    <description>Go to a robot repair station for self-repair.</description>
    <driverClass>RobotRepairStation.JobDriver_GoToRepairStation</driverClass>
    <reportString>going to repair station.</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
    <playerInterruptible>true</playerInterruptible>
    <checkOverrideOnDamage>false</checkOverrideOnDamage>
  </JobDef>

  <!-- Job: El mecanoid está docked y siendo reparado -->
  <JobDef>
    <defName>RRS_RepairAtStation</defName>
    <label>repairing at station</label>
    <description>Being repaired at the robot repair station.</description>
    <driverClass>RobotRepairStation.JobDriver_RepairAtStation</driverClass>
    <reportString>repairing at station.</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
    <playerInterruptible>true</playerInterruptible>
    <checkOverrideOnDamage>false</checkOverrideOnDamage>
    <casualInterruptible>false</casualInterruptible>
  </JobDef>

</Defs>
